# ============================================================
# Kalshi API Client — Required Environment Variables
# Copy this file to .env and fill in real values.
# .env is never committed. This file is safe to commit.
# ============================================================

# ---------------------------------------------------------------------------
# Authentication (REQUIRED)
# ---------------------------------------------------------------------------

# Your Kalshi API key ID. Obtain from https://kalshi.com/account/api-keys
# This is the key identifier (not the secret). Sent in KALSHI-ACCESS-KEY header.
# Example: "abc123def456"
KALSHI_API_KEY=

# RSA private key for request signing (RSA-PSS, SHA-256, MGF1-SHA256).
# Kalshi requires RSA-PSS authentication since API v3. HMAC-SHA256 is no longer used.
#
# Provide EITHER KALSHI_PRIVATE_KEY_PEM (inline PEM text) OR
#                KALSHI_PRIVATE_KEY_PATH (path to a .pem file).
# If both are set, KALSHI_PRIVATE_KEY_PEM takes precedence.
#
# Generate a key pair with:
#   openssl genrsa -out kalshi_private.pem 2048
#   openssl rsa -in kalshi_private.pem -pubout -out kalshi_public.pem
# Then upload the PUBLIC key to https://kalshi.com/account/api-keys.
# Keep the PRIVATE key secret — never commit it.

# Option A: inline PEM (convenient for CI/CD secrets managers, single-line with \n escapes)
KALSHI_PRIVATE_KEY_PEM=

# Option B: path to the .pem file on disk (convenient for local development)
# Example: "/Users/yourname/secrets/kalshi_private.pem"
KALSHI_PRIVATE_KEY_PATH=

# ---------------------------------------------------------------------------
# API Endpoint (REQUIRED)
# ---------------------------------------------------------------------------

# Base URL for the Kalshi REST API (host only — no trailing slash, no /trade-api/v2 suffix).
# Demo (paper trading):    https://external-api.demo.kalshi.co
# Production (live funds): https://external-api.kalshi.com
# Use demo until the system is fully validated.
KALSHI_BASE_URL=https://external-api.demo.kalshi.co

# ---------------------------------------------------------------------------
# Logging (REQUIRED)
# ---------------------------------------------------------------------------

# Absolute path to the rotating log file.
# The file will rotate daily and keep 7 days of history.
# The directory must exist and be writable.
# Example: "/var/log/kalshi/kalshi_client.log"
# Example: "/Users/yourname/Axiom/logs/kalshi_client.log"
KALSHI_LOG_FILE_PATH=

# Log verbosity level. One of: DEBUG, INFO, WARNING, ERROR, CRITICAL.
# Use DEBUG during development to see every API call.
# Use INFO or WARNING in production to reduce noise.
KALSHI_LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Tuning (OPTIONAL — defaults shown)
# ---------------------------------------------------------------------------

# HTTP request timeout in seconds.
# If a Kalshi API call takes longer than this, it is retried with backoff.
# Raise this if you see frequent timeout errors on slow connections.
# Default: 10
KALSHI_TIMEOUT_SECONDS=10

# Maximum number of retry attempts on transient failures (429, 5xx, timeout).
# Retries use exponential backoff with ±20% jitter.
# Delays: ~1s, ~4s, ~16s. After max retries, a terminal error is raised.
# Default: 3
KALSHI_MAX_RETRIES=3
